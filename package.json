{
  "name": "mini-dungeon-commander",
  "version": "1.0.0",
  "type": "module",
  "description": "迷你地下城指挥官 - 战术自动战斗 Roguelike 游戏",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dist:win": "npm run build && electron-builder --win portable --x64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.3",
    "vite": "^8.1.4"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.ey1afjalla.mini-dungeon-commander",
    "productName": "Mini Dungeon Commander",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "MiniDungeonCommander-${version}-Windows-Portable.exe"
    }
  }
}
